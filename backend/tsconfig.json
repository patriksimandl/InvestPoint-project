{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "strict": false,
    "isolatedModules": true,
    "types": ["node", "jest"]
  },
  "include": [
    "**/*.ts",
    "**/*.js"
  ]
}
